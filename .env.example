# ─────────────────────────────────────────────────────────────
# Myfxbook auto-sync credentials
# ─────────────────────────────────────────────────────────────
# These power /api/myfxbook/sync. When BOTH are set, the app pulls
# live account data from Myfxbook on every load and via the daily
# Vercel cron. When EITHER is missing, the app falls back to the
# verified static data in src/data/signals.ts and the badge shows
# "VERIFIED" instead of "LIVE".
#
# LOCAL DEV:  copy this file to .env  and fill in real values.
# PRODUCTION: set these in Vercel → Project → Settings →
#             Environment Variables (Production scope), then redeploy.
#
# Use the same email + password you log into myfxbook.com with.
MYFXBOOK_EMAIL=your_email@example.com
MYFXBOOK_PASSWORD=your_myfxbook_password
